<!DOCTYPE html>

<html prefix="og: http://ogp.me/ns#">
<head>
  <meta charset="UTF-8">

  <%# テーマオプション %>
  <meta name="font:Body" content="Helvetica Neue"/>

  <meta name="color:Background" content="#1A1A1A"/>
  <meta name="color:Text" content="#ffffff"/>
  <meta name="color:Caption" content="#BFBFBF"/>

  <meta name="image:Title Logo" content=""/>

<meta name="text:Your Name" content="" />
  <meta name="text:Profile" content="" />

  <meta name="text:Your Website URL" content=""/>


  <title>{block:PostSummary}{PostSummary} - {/block:PostSummary}{Title}</title>

  <meta name="viewport" content="width=device-width">
  <link rel="shortcut icon" href="{Favicon}">
  <link rel="apple-touch-icon" href="{PortraitURL-128}">

  <!-- static css file -->
  <link rel="stylesheet" type="text/css" media="screen" href="https://static.tumblr.com/xo6rund/uq2tatpz0/index.css"> 
  <!-- 開発用 local cssエントリポイント -->
  <!-- <link rel="stylesheet" type="text/css" media="screen" href="./styles/main.css"> -->

  <%# カスタマイズパネルの値を CSS カスタムプロパティとして出力 %>
  <%# 外部CSSのデフォルト値をここで上書きする %>
  <style>
    :root {
      --c-bg: {color:Background};
      --c-text: {color:Text};
      --c-caption: {color:Caption};
    }
    body {
      font-family: "{font:Body}", sans-serif;
    }
  </style>

  <%# OGP %>
  <meta property="og:title" content="{block:PostSummary}{PostSummary} - {/block:PostSummary}{Title}" />
  <meta property="og:type" content="article" />

  <meta name="twitter:card" content="summary_large_image">
  {block:IndexPage}
    <meta property="og:image" content="{HeaderImage}" />
    <meta name="twitter:image:src" content="{HeaderImage}" />
  {/block:IndexPage}
  {block:PermalinkPage}
    {block:Posts}
      {block:Photo}
        <meta property="og:image" content="{PhotoURL-HighRes}" />
        <meta name="twitter:image:src" content="{PhotoURL-HighRes}" />
      {/block:Photo}
      {block:Photoset}
        {block:Photos}
        <meta property="og:image" content="{PhotoURL-HighRes}" />
        <meta name="twitter:image:src" content="{PhotoURL-HighRes}" />
        {/block:Photos}
      {/block:Photoset}
    {/block:Posts}
  {/block:PermalinkPage}

  <meta property="og:site_name" content="{Title}" />
  {block:Description}
    <meta property="og:description" content="{MetaDescription}">
  {/block:Description}
  {block:IndexPage}
    <link rel="canonical" href="{BlogURL}"/>
    <meta property="og:url" content="{BlogURL}" />
  {/block:IndexPage}
  {block:PermalinkPage}
    <link rel="canonical" href="{Permalink}"/>
    <meta property="og:url" content="{Permalink}" />
  {/block:PermalinkPage}

  <script src="https://unpkg.com/infinite-scroll@4/dist/infinite-scroll.pkgd.min.js"></script>


</head>

<body class="
{block:IndexPage}page-index{/block:IndexPage}
{block:TagPage}page-tag{/block:TagPage}
{block:PermalinkPage}page-permalink page-{PostID}{/block:PermalinkPage}"
>

<div class="wrapper">
  <header class="c-header">
    {block:IfTitleLogo}
      <a href="{BlogURL}" class="c-logo-link">
        <img class="c-logo-img" src="{image:Title Logo}" alt="{Title}"/>
      </a>
    {/block:IfTitleLogo}
    <h1 class="c-logo">{Title}</h1>
    <p class="c-header-link">
      {block:IfYourWebsiteURL}
        <a class="t-link" href="{text:Your Website URL}">{text:Your Website URL}</a>
      {/block:IfYourWebsiteURL}
    </p>
    <p class="c-header-link">
      <a class="t-link" href="/archive">Archive</a>
    </p>
    {block:IfYourName}
      <p class="c-name">{text:Your Name}</p>
    {/block:IfYourName}
    {block:Description}
      <p class="c-description" id="description">{Description}</p>
    {/block:Description}
    {block:IfProfile}
      <p class="c-profile">{text:Profile}</p>
    {/block:IfProfile}
  </header>